@using SharpIDE.Application.Features.Build

@inject BuildService BuildService

@implements IDisposable

<TerminalDisplay @ref="@_terminalDisplayRef"/>

@code {
	private TerminalDisplay _terminalDisplayRef = null!;

	protected override async Task OnInitializedAsync()
	{
		BuildService.BuildStarted.Subscribe(ClearPreviousOutput);
		_ = Task.Run(async () =>
		{
			try
			{
				while (true)
				{
					var readResult = await BuildService.BuildLogPipeReader!.ReadAsync();
					var byteSequence = readResult.Buffer;
					if (byteSequence.IsEmpty)
					{
						BuildService.BuildLogPipeReader.AdvanceTo(byteSequence.End);
						return;
					}
					foreach (var segment in byteSequence)
					{
						await _terminalDisplayRef.Write(segment);
					}
					BuildService.BuildLogPipeReader.AdvanceTo(byteSequence.End);
				}
			}
			catch (Exception e)
			{
				await DispatchExceptionAsync(e);
			}
		});
	}

	private async Task ClearPreviousOutput(BuildStartedFlags _)
	{
		await _terminalDisplayRef.Clear();
		await InvokeAsync(StateHasChanged);
	}

	public void Dispose() => BuildService.BuildStarted.Unsubscribe(ClearPreviousOutput);
}
